{
  "name": "modcut",
  "version": "0.0.1",
  "description": "Modern cross-platform laser control for Horten Folkeverksted (a modernized VisiCut).",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "build:sidecar": "javac -d sidecar/out sidecar/Sidecar.java",
    "prestart": "npm run build:sidecar",
    "start": "electron .",
    "test:bridge": "npm run build:sidecar && node electron/test-bridge.mjs",
    "check:contrast": "node design/check-contrast.mjs"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "dependencies": {
    "paper": "^0.12.18"
  }
}
